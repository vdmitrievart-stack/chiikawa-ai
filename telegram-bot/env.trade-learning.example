# Chiikawa V17 Trade Learning / Strategy Self-Analysis
# Safe default: enabled. It only changes entry behavior after repeated patterns,
# not after one random loss.

TRADE_LEARNING_ENABLED=true
TRADE_LEARNING_NOTIFY=true
TRADE_LEARNING_DATA_FILE=./runtime-data/trade-learning-memory.json

# Minimum sample sizes before behavior is adjusted.
TRADE_LEARNING_MIN_STRATEGY_TRADES=5
TRADE_LEARNING_MIN_FACTOR_TRADES=3
TRADE_LEARNING_MIN_COMBO_TRADES=4

# Loss-rate thresholds. 0.60 = 60% losses in a repeated sample.
TRADE_LEARNING_WARN_LOSS_RATE=0.60
TRADE_LEARNING_BLOCK_LOSS_RATE=0.78

# Average PnL thresholds for corrections.
TRADE_LEARNING_WARN_AVG_PNL_PCT=-3
TRADE_LEARNING_BLOCK_AVG_PNL_PCT=-8

# How much closed-trade history to keep in learning memory.
TRADE_LEARNING_MAX_TRADES=600
