# Devs Nightmare integration for Chiikawa Telegram Bot
# Fill these only if you have an official/private Devs Nightmare API endpoint.
# The bot will continue working without them and will use local RPC/holder heuristics.

# auto = enabled only when DEVSNIGHTMARE_API_URL is present
DEVSNIGHTMARE_ENABLED=auto

# Supported formats:
# 1) https://your-devsnightmare-api.example.com/token?ca={ca}
# 2) https://your-devsnightmare-api.example.com/token   -> bot appends ?ca=<CA>
DEVSNIGHTMARE_API_URL=

# Optional API key/header. Leave empty if the endpoint does not require a key.
DEVSNIGHTMARE_API_KEY=
DEVSNIGHTMARE_AUTH_HEADER=x-api-key

# Optional Bearer auth if your provider gives a bearer token instead of x-api-key.
DEVSNIGHTMARE_BEARER_TOKEN=

# Timeouts/cache to avoid Telegram/report delays.
DEVSNIGHTMARE_TIMEOUT_MS=6500
DEVSNIGHTMARE_CACHE_TTL_MS=300000
